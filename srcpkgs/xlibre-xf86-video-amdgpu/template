build_style=gnu-configure
configure_args="--prefix=/usr --enable-glamor"
hostmakedepends="pkg-config xorg-util-macros autoconf automake libtool git"
makedepends="xlibre-xserver-devel eudev-libudev-devel libpciaccess-devel libdrm-devel pixman-devel MesaLib-devel autoconf xorgproto automake fakeroot gawk gettext libtool m4 pkgconf xorg-util-macros libXfont2-devel"
depends="virtual?xserver-abi-video-28_1 mesa-dri"
