# Template file for 'xlibre-xserver'
pkgname=xlibre-xserver
version=25.1.4
revision=1
build_style=meson
configure_args="-Dipv6=true -Dxorg=true -Dxnest=true -Dxephyr=true -Dxfbdev=true -Dxvfb=true -Dhal=false -Dudev=true -Dxkb_dir=/usr/share/X11/xkb -Dxkb_output_dir=/var/lib/xkb -Dlinux_acpi=true -Dlinux_apm=false -Dsuid_wrapper=true -Dxcsecurity=true -Dglamor=true -Ddri2=true -Ddri3=true -Dglx=true -Dsystemd_logind=$(vopt_if elogind true false)"
hostmakedepends="pkg-config xkbcomp flex xorgproto gawk"
makedepends="MesaLib-devel libXaw-devel libXfont2-devel libXrender-devel libXres-devel libXtst-devel libXv-devel libXxf86dga-devel libdmx-devel libepoxy-devel openssl-devel libtirpc-devel libxkbfile-devel libxkbui-devel libxshmfence-devel pixman-devel xcb-util-image-devel xcb-util-keysyms-devel xcb-util-renderutil-devel xcb-util-wm-devel xkbcomp nettle-devel libxcvt-devel font-util $(vopt_if elogind 'dbus-devel')"
depends="xkeyboard-config $(vopt_if elogind 'elogind')"
short_desc="Fork of Xorg with lots of code cleanups and enhanced functionality"
maintainer="Sofiya <sofiya@v.com>"
license="MIT, BSD-3-Clause"
homepage="https://x11libre.net/"
distfiles="https://github.com/X11Libre/xserver/archive/refs/tags/xlibre-xserver-${version}.tar.gz"
checksum=de5f19fe9ea5a020db6fc114195b6dd1c4106d5796d2259a78b9e74d363b265a
provides="xserver-abi-extension-11_1 xserver-abi-input-26_1 xserver-abi-video-28_1 xf86-video-modesetting-1_1"
replaces="xf86-video-modesetting>=0 glamor-egl>=0"
conf_files="/etc/X11/Xwrapper.config"
build_options="elogind"
desc_option_elogind="Rootless XLibre support with elogind"
conflicts="xorg-server"
lib32disabled=yes


# disable VBE on non-x86 systems
case "$XBPS_TARGET_MACHINE" in
    x86_64*|i686*) configure_args+=" -Dint10=x86emu" ;;
    *) configure_args+=" -Dint10=false" ;;
esac

# Symbols must be resolved lazily for modules to work.
# See https://bugs.freedesktop.org/show_bug.cgi?id=41208#c5
LDFLAGS="-Wl,-z,lazy"

pre_configure() {
    case "$XBPS_TARGET_MACHINE" in
    *-musl)
        export CFLAGS+=" -D__uid_t=uid_t -D__gid_t=gid_t"
        ;;
    esac
}

post_install() {
    vinstall ${FILESDIR}/Xwrapper.config 644 etc/X11
    vlicense COPYING
    chmod 4755 ${DESTDIR}/usr/libexec/Xorg.wrap
    find "${DESTDIR}"/usr/share/man -type f -iname '*[1-5].gz' -exec gunzip '{}' \;
    pkg_install()
    {
        vmove usr/lib/xorg/protocol.txt
    }
}

xlibre-xserver-xnest_package() {
    short_desc="Nested X server that runs as an X application"
    # depends="libXfont2 libunwind libXext pixman nettle libtirpc libXdmcp libX11 libXau"
    conflicts="xorg-server-xnest"
    replaces="xorg-server-xnest>=0"
    pkg_install()
    {
        vlicense COPYING
        vmove usr/bin/Xnest
        vmove usr/share/man/man1/Xnest.1
    }
}

xlibre-xserver-xephyr_package() {
    short_desc="X server outputting to a window on a pre-existing X display"
    # depends="libXfont2 libglvnd libepoxy libunwind xcb-util-image xcb-util-renderutil xcb-util-wm xcb-util-keysyms pixman nettle libtirpc xcb-util libXdmcp libX11 libXau libxshmfence"
    conflicts="xorg-server-xephyr"
    replaces="xorg-server-xephyr>=0"
    pkg_install()
    {
        vlicense COPYING
        vmove usr/bin/Xephyr
        vmove usr/share/man/man1/Xephyr.1
    }
}

xlibre-xserver-xvfb_package() {
    short_desc="Virtual framebuffer X server"
    # depends="libXfont2 libunwind pixman xauth libglvnd nettle libtirpc libXdmcp libXau xkeyboard-config"
    conflicts="xorg-server-xvfb"
    replaces="xorg-server-xvfb>=0"
    pkg_install()
    {
        vlicense COPYING
        vmove usr/bin/Xvfb
        vmove usr/share/man/man1/Xvfb.1
    }
}

xlibre-xserver-common_package() {
    short_desc+="- common files"
    conflicts="xorg-server-common"
    replaces="xorg-server-common>=0"
    pkg_install() {
        vlicense COPYING
        vmove usr/lib/xorg/protocol.txt
        vmove usr/share/man/man1/Xserver.1
    }
}

xlibre-xserver-devel_package() {
     short_desc+=" - development files"
     depends="${makedepends}"
     conflicts="xorg-server-devel"
     replaces="xorg-server-devel>=0"
     pkg_install() {
         vlicense COPYING
         vmove usr/include
         vmove usr/lib/pkgconfig
         vmove usr/share/aclocal
     }
 }
